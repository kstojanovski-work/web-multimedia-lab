# Preferred simple TURN config:
WEBRTC_TURN_URL=turn:YOUR_TURN_HOST:3478?transport=udp
WEBRTC_TURN_USERNAME=YOUR_USER
WEBRTC_TURN_CREDENTIAL=YOUR_PASS

# Alternative (advanced): full JSON list is used when WEBRTC_TURN_URL is not set
# WEBRTC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:YOUR_TURN_HOST:3478?transport=udp","username":"YOUR_USER","credential":"YOUR_PASS"},{"urls":"turn:YOUR_TURN_HOST:3478?transport=tcp","username":"YOUR_USER","credential":"YOUR_PASS"}]
