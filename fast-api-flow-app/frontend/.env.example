VITE_BACKEND_URL=http://localhost:8000
# Preferred simple TURN config:
VITE_TURN_URL=turn:YOUR_TURN_HOST:3478?transport=udp
VITE_TURN_USERNAME=YOUR_USER
VITE_TURN_CREDENTIAL=YOUR_PASS

# Alternative (advanced): full JSON list overrides defaults when no VITE_TURN_URL is set
# VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:YOUR_TURN_HOST:3478?transport=udp","username":"YOUR_USER","credential":"YOUR_PASS"},{"urls":"turn:YOUR_TURN_HOST:3478?transport=tcp","username":"YOUR_USER","credential":"YOUR_PASS"}]
